# MongoDB Connection String
# Get from MongoDB Atlas and replace with your actual connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME

# Server Port
PORT=5000

# JWT Secrets - Generate new secure secrets!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_secret_access_key_here
JWT_REFRESH_SECRET=your_secret_refresh_key_here

# Frontend - Backend API URL
VITE_API_BASE_URL=https://https://dashboard.render.com/project/prj-d8at133bc2fs73e5m39g
